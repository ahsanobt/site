<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact NEXUS</title>
    <style>
        body { background-color: #000; color: #fff; font-family: 'Inter', sans-serif; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }
        .form-card { background: #111; padding: 40px; border-radius: 15px; border: 1px solid #333; width: 100%; max-width: 400px; }
        h2 { margin-top: 0; letter-spacing: 2px; }
        input, textarea { width: 100%; padding: 12px; margin-bottom: 20px; background: #222; border: 1px solid #444; color: #fff; border-radius: 5px; box-sizing: border-box; }
        button { width: 100%; padding: 15px; background: #fff; color: #000; border: none; font-weight: bold; cursor: pointer; transition: 0.3s; }
        button:hover { background: #ccc; }
        #success-msg { display: none; color: #00ff00; text-align: center; margin-top: 10px; }
    </style>
</head>
<body>

<div class="form-card">
    <h2>GET IN TOUCH</h2>
    <form id="nexus-form">
        <input type="text" name="Name" placeholder="Your Name" required>
        <input type="email" name="Email" placeholder="Your Email" required>
        <textarea name="Message" placeholder="How can we scale your brand?" rows="4" required></textarea>
        <button type="submit" id="submit-btn">SEND TO SHEETS</button>
    </form>
    <div id="success-msg">✔ Data sent to Google Sheets!</div>
</div>

<script>
    const scriptURL = 'https://script.google.com/macros/s/AKfycbzULLJm8jXEtLXhJUUHsClo4p3bZWripfjC8E6xbM36XueipPFt6SWOpiYAXwP3Jm6m/exec'
    const form = document.getElementById('nexus-form')
    const msg = document.getElementById('success-msg')

    form.addEventListener('submit', e => {
        e.preventDefault()
        document.getElementById('submit-btn').innerText = "CONNECTING..."
        
        fetch(scriptURL, { method: 'POST', body: new FormData(form)})
            .then(response => {
                msg.style.display = "block"
                form.reset()
                document.getElementById('submit-btn').innerText = "SEND TO SHEETS"
            })
            .catch(error => alert('Error! Check your script permissions.'))
    })
</script>

</body>
</html>
